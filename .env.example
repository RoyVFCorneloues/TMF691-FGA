# Auth0 FGA Configuration
FGA_API_URL=https://api.eu1.fga.dev
FGA_STORE_ID=your_store_id
FGA_MODEL_ID=your_model_id
FGA_CLIENT_ID=your_client_id
FGA_CLIENT_SECRET=your_client_secret

# Provider Selection (optional — defaults shown)
AUTH_PROVIDER=auth0
DATA_PROVIDER=json

# Data Source File Selection (optional — defaults to tmfData.json)
# Uncomment or set to switch between different data sources
# TMF_DATA_SOURCE=scenarios.json
